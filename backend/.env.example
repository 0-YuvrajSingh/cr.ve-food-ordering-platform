# ──────────────────────────────────────
# MongoDB
# ──────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/crve?retryWrites=true&w=majority

# ──────────────────────────────────────
# Server
# ──────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────
# Firebase Admin SDK
# (From Firebase Console > Project Settings > Service Accounts > Generate new private key)
# ──────────────────────────────────────
FIREBASE_PROJECT_ID=codebase-ccc2f
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@codebase-ccc2f.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ──────────────────────────────────────
# Razorpay
# (From razorpay.com > Settings > API Keys)
# ──────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
